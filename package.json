{
  "name": "cricknote",
  "version": "0.1.0",
  "description": "Scientific research assistant for Obsidian",
  "type": "module",
  "bin": {
    "cricknote": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "build:plugin": "bash scripts/build-plugin.sh",
    "dev": "tsc --watch",
    "start": "node dist/cli.js start",
    "setup": "node dist/cli.js setup",
    "reindex": "node dist/cli.js reindex",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@xenova/transformers": "^2.17.0",
    "better-sqlite3": "^11.7.0",
    "chokidar": "^4.0.0",
    "chrono-node": "^2.7.0",
    "commander": "^13.0.0",
    "diff": "^7.0.0",
    "gray-matter": "^4.0.3",
    "inquirer": "^12.0.0",
    "node-cron": "^3.0.3",
    "openai": "^4.77.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/diff": "^6.0.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.13",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
